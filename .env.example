# Firebase Admin SDK private credentials.
# Use only one of the following credential variables at the same time.
# Never paste real secrets into committed files.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_CONFIG_PATH=./config/firebase-service-account.json

# Firebase project metadata used by Admin SDK clients.
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Public URL used by generated incident photo links.
APP_PUBLIC_BASE_URL=http://10.0.2.2:8080

# Comma-separated origins allowed by CORS. Do not use * with bearer-token requests.
APP_CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://127.0.0.1:5173
